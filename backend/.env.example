# 应用配置
APP_NAME=学吧
APP_VERSION=0.1.0
DEBUG=true

# 数据库
DATABASE_URL=postgresql+asyncpg://xueba:xueba@localhost:5432/xueba

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM 配置
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# Audit Agent 配置
AUDIT_AGENT_URL=http://localhost:8001
AUDIT_TIMEOUT=600

# 微信小程序
WECHAT_APP_ID=your-app-id
WECHAT_APP_SECRET=your-app-secret

# JWT
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168
