<view class="container">
  <view class="header">
    <text class="title">我的学习项目</text>
    <view class="btn-primary" bindtap="createProject">+ 新建项目</view>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{projects.length === 0}}" class="empty">
    <text>还没有学习项目，点击上方按钮创建一个吧！</text>
  </view>

  <view wx:else class="project-list">
    <view class="card project-card" wx:for="{{projects}}" wx:key="id" bindtap="goToProject" data-id="{{item.id}}">
      <view class="project-title">{{item.subject}}</view>
      <view class="project-goal">{{item.goal_description}}</view>
      <view class="project-meta">
        <text>节点: {{item.tree_total_nodes || 0}}</text>
        <text>学时: {{item.tree_total_hours || 0}}h</text>
      </view>
    </view>
  </view>
</view>
