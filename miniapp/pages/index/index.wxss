/* pages/index/index.wxss */

.user-card {
  padding: 40rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.study-days {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.login-card {
  text-align: center;
  padding: 60rpx 40rpx;
}

.login-card .title {
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.login-card .subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
  display: block;
}

.section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.task-item {
  padding: 24rpx 30rpx;
}

.task-title {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.task-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.task-item .progress-bar {
  margin-top: 16rpx;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #666;
}
