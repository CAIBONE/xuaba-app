/* 今日学习卡片 */
.daily-schedule {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  margin-bottom: var(--spacing-lg);
  cursor: pointer;
  transition: transform 0.2s ease;
}

.daily-schedule:active {
  transform: scale(0.98);
}

.schedule-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.schedule-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.schedule-title {
  font-size: 32rpx;
  font-weight: bold;
}

.schedule-desc {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
  display: block;
}

.schedule-action {
  display: flex;
  justify-content: flex-end;
}

.action-text {
  font-size: 26rpx;
  font-weight: 500;
  opacity: 0.9;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.project-card {
  cursor: pointer;
  transition: transform 0.2s ease;
}

.project-card:active {
  transform: scale(0.98);
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.project-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  flex: 1;
}

.project-goal {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
  line-height: 1.6;
}

.project-baseline {
  background: #f0f9ff;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  margin-bottom: var(--spacing-md);
}

.baseline-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.baseline-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.project-stats {
  display: flex;
  justify-content: space-around;
  padding-top: var(--spacing-md);
  border-top: 2rpx solid var(--border-color);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
}
