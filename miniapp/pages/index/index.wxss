.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
}

.project-card {
  cursor: pointer;
}

.project-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.project-goal {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.project-meta {
  display: flex;
  gap: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
