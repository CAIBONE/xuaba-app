.node-info {
  margin-bottom: 20rpx;
}

.node-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.node-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.node-meta {
  display: flex;
  gap: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.tabs {
  display: flex;
  background: white;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  padding: 25rpx;
  text-align: center;
  font-size: 30rpx;
  cursor: pointer;
}

.tab.active {
  background: #07c160;
  color: white;
}

.empty {
  text-align: center;
  padding: 60rpx 30rpx;
}

.empty text {
  display: block;
  margin-bottom: 30rpx;
  color: #999;
}

.content-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.content-stats {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-heading {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #07c160;
}

.section-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.question {
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.question:last-child {
  border-bottom: none;
}

.question-header {
  font-size: 26rpx;
  color: #07c160;
  margin-bottom: 10rpx;
}

.question-content {
  font-size: 30rpx;
  margin-bottom: 15rpx;
}

.options {
  margin-bottom: 15rpx;
}

.option {
  font-size: 28rpx;
  padding: 10rpx 0;
}

.answer, .explanation {
  font-size: 26rpx;
  margin-top: 10rpx;
  padding: 15rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.answer-label, .explanation-label {
  font-weight: bold;
  color: #07c160;
}

.disabled {
  opacity: 0.5;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
