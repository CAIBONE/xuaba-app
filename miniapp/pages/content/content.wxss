/* pages/content/content.wxss */

.content-header {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.content-meta {
  display: flex;
  gap: 30rpx;
  margin-top: 16rpx;
}

.content-meta text {
  font-size: 24rpx;
  color: #999;
}

.content-body {
  padding: 30rpx;
  margin-bottom: 120rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-heading {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.content-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.content-actions button {
  flex: 1;
}
