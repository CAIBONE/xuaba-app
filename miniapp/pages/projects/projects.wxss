/* pages/projects/projects.wxss */

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.btn-small {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
}

.project-card {
  padding: 30rpx;
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.project-subject {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.project-goal {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-stats {
  display: flex;
  justify-content: space-around;
  margin: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A90E2;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.empty {
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
}
