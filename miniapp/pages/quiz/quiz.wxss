/* pages/quiz/quiz.wxss */

.quiz-header {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.progress {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin: 12rpx 0;
}

.question-card {
  padding: 40rpx 30rpx;
  margin-bottom: 120rpx;
}

.question-type {
  font-size: 24rpx;
  color: #4A90E2;
  display: block;
  margin-bottom: 16rpx;
}

.question-content {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
}

.option.selected {
  border-color: #4A90E2;
  background: #f0f7ff;
}

.option-label {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 20rpx;
}

.option.selected .option-label {
  background: #4A90E2;
  color: #fff;
}

.option-text {
  font-size: 28rpx;
  color: #333;
}

.quiz-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.quiz-actions button {
  flex: 1;
}

.result-card {
  text-align: center;
  padding: 60rpx 40rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 30rpx;
}

.result-score {
  font-size: 48rpx;
  color: #4A90E2;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.result-detail {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 40rpx;
}

/* Feedback Section */
.feedback-section {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.feedback-title {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.feedback-buttons {
  display: flex;
  gap: 20rpx;
}

.feedback-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fff;
}

.feedback-btn.active.confused {
  border-color: #faad14;
  background: #fffbe6;
}

.feedback-btn.active.familiar {
  border-color: #52c41a;
  background: #f6ffed;
}

.feedback-btn.active.unclear {
  border-color: #1890ff;
  background: #e6f7ff;
}

.feedback-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.feedback-text {
  font-size: 24rpx;
  color: #666;
}

.feedback-btn.active .feedback-text {
  color: #333;
  font-weight: 500;
}

/* Feedback Summary */
.feedback-summary {
  margin: 40rpx 0;
  padding: 30rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.feedback-summary-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 20rpx;
}

.feedback-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}
