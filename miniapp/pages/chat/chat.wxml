<!--pages/chat/chat.wxml-->
<view class="container">
  <view class="chat-header">
    <text class="title">AI 学习助手</text>
    <text class="subtitle">基于项目知识的智能对话</text>
  </view>

  <scroll-view class="chat-messages" scroll-y="true" scroll-into-view="{{scrollToView}}">
    <view class="message-item {{item.role}}" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <view class="message-avatar">
        <text>{{item.role === 'user' ? '👤' : '🤖'}}</text>
      </view>
      <view class="message-content">
        <text class="message-text">{{item.content}}</text>
        <text class="message-time">{{item.time}}</text>
      </view>
    </view>
    <view class="message-item assistant" wx:if="{{loading}}">
      <view class="message-avatar">
        <text>🤖</text>
      </view>
      <view class="message-content">
        <text class="message-text typing">正在思考...</text>
      </view>
    </view>
  </scroll-view>

  <view class="chat-input-area">
    <input class="chat-input" placeholder="输入你的问题..." bindinput="onInput" value="{{inputValue}}" confirm-type="send" bindconfirm="sendMessage" />
    <button class="send-btn" bindtap="sendMessage" disabled="{{!inputValue || loading}}">发送</button>
  </view>
</view>
