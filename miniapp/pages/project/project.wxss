.project-info {
  margin-bottom: 30rpx;
}

.project-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.project-goal {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.project-stats {
  display: flex;
  gap: 40rpx;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.node-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.node-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  cursor: pointer;
}

.node-level {
  background: #07c160;
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  height: fit-content;
}

.node-content {
  flex: 1;
}

.node-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.node-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.node-meta {
  font-size: 24rpx;
  color: #999;
}

.empty-tree {
  text-align: center;
  padding: 60rpx 30rpx;
}

.empty-tree text {
  display: block;
  margin-bottom: 30rpx;
  color: #999;
}

.disabled {
  opacity: 0.5;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* Progress bar */
.generation-progress {
  margin: 30rpx 0;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 15rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #10b981);
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

/* Section title with batch actions */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.batch-actions {
  display: flex;
  gap: 10rpx;
}

.btn-small {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  border: 1px solid #ddd;
  background: white;
}

.btn-small.btn-primary {
  background: #07c160;
  color: white;
  border: none;
}

/* Node status */
.node-status-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.status-completed,
.status-content,
.status-pending {
  font-size: 32rpx;
}

/* Node selected state */
.node-item.selected {
  background: #e6f7ff;
  border: 2rpx solid #1890ff;
}

.node-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  font-size: 28rpx;
  color: #07c160;
}

.node-item.selected .node-checkbox {
  background: #07c160;
  color: white;
  border-color: #07c160;
}

.empty-tree .btn-secondary {
  margin-top: 20rpx;
  background: #f0f0f0;
  color: #333;
  border: 1px solid #ddd;
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}
