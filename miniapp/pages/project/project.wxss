.project-info {
  margin-bottom: 30rpx;
}

.project-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.project-goal {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.project-stats {
  display: flex;
  gap: 40rpx;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.node-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.node-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  cursor: pointer;
}

.node-level {
  background: #07c160;
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  height: fit-content;
}

.node-content {
  flex: 1;
}

.node-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.node-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.node-meta {
  font-size: 24rpx;
  color: #999;
}

.empty-tree {
  text-align: center;
  padding: 60rpx 30rpx;
}

.empty-tree text {
  display: block;
  margin-bottom: 30rpx;
  color: #999;
}

.disabled {
  opacity: 0.5;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
