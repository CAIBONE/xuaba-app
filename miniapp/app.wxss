page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background-color: #f5f5f5;
  --primary-color: #07c160;
  --secondary-color: #576b95;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border-color: #e5e5e5;
  --border-radius: 16rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
}

.container {
  padding: var(--spacing-md);
}

.card {
  background: var(--card-bg);
  border-radius: var(--border-radius);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: var(--primary-color);
  color: white;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 32rpx;
  border: none;
}

.btn-secondary {
  background: white;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-lg);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

/* Loading 状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--spacing-md);
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--spacing-lg);
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-lg);
}

.empty-text {
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-tag.active {
  background: #e8f5e9;
  color: #2e7d32;
}

.status-tag.completed {
  background: #e3f2fd;
  color: #1565c0;
}

.status-tag.pending {
  background: #fff3e0;
  color: #e65100;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 16rpx;
  background: var(--border-color);
  border-radius: 8rpx;
  overflow: hidden;
  margin: var(--spacing-md) 0;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color) 0%, #10b981 100%);
  transition: width 0.3s ease;
}
